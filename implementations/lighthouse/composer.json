{
    "require": {
        "php": "^8.5",
        "laravel/framework": "^13",
        "nuwave/lighthouse": "^6.66",
        "google/protobuf": "^4.33.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
